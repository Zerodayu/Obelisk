model user {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false) @map("email_verified")
  image         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // --- Institutional extensions ---
  role         UserRole @default(user)
  employeeId   String?  @unique @map("employee_id")
  programId    String?  @map("program_id")
  departmentId String?  @map("department_id")
  isActive     Boolean  @default(true) @map("is_active")

  // Forward relations
  program    Program?    @relation(fields: [programId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])

  // Back-relations
  sessions                  session[]
  accounts                  account[]
  departmentsAsDean         Department[]       @relation("Dean")
  programsAsChair           Program[]          @relation("ProgramChair")
  classSectionsAsFaculty    ClassSection[]     @relation("Faculty")
  formSubmissions           FormSubmission[]   @relation("Submitter")
  approvalSteps             ApprovalStep[]     @relation("Approver")
  computationRuns           ComputationRun[]   @relation("TriggeredBy")
  auditLogs                 AuditLog[]         @relation("AuditUser")
  aiRecommendationsReviewed AiRecommendation[] @relation("Reviewer")
  reportExports             ReportExport[]     @relation("Exporter")

  @@map("user")
}

model session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model account {
  id                    String    @id @default(cuid())
  userId                String    @map("user_id")
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("verification")
}
